---
import type { UI } from '../i18n/ui';

interface Props {
  rating: number;
  max?: number;
  tested?: string;
  pros?: string[];
  cons?: string[];
  weakerThan?: string;
  missed?: string;
  labels: UI['ui']['review'];
}
const { rating, max = 5, tested, pros = [], cons = [], weakerThan, missed, labels } = Astro.props;
const pct = Math.max(0, Math.min(100, (rating / max) * 100));
---
<aside class="verdict">
  <p class="verdict__kicker">{labels.verdict}</p>

  <div class="verdict__head">
    <div class="verdict__score">
      <span class="verdict__num">{rating.toFixed(1)}</span>
      <span class="verdict__den">/ {max}</span>
    </div>
    <span class="stars" style={`--fill:${pct}%`} aria-hidden="true">
      <span class="stars__base">★★★★★</span>
      <span class="stars__fill">★★★★★</span>
    </span>
  </div>

  {tested && <p class="verdict__tested"><strong>{labels.tested}:</strong> {tested}</p>}

  <div class="verdict__grid">
    <!-- Negatives first, on purpose: this is what readers can't get elsewhere. -->
    {cons.length > 0 && (
      <div class="verdict__block verdict__block--warn">
        <h3>{labels.cons}</h3>
        <ul>{cons.map((c) => <li>{c}</li>)}</ul>
      </div>
    )}
    {weakerThan && (
      <div class="verdict__block verdict__block--warn">
        <h3>{labels.weaker}</h3>
        <p>{weakerThan}</p>
      </div>
    )}
    {pros.length > 0 && (
      <div class="verdict__block">
        <h3>{labels.pros}</h3>
        <ul>{pros.map((p) => <li>{p}</li>)}</ul>
      </div>
    )}
    {missed && (
      <div class="verdict__block">
        <h3>{labels.missed}</h3>
        <p>{missed}</p>
      </div>
    )}
  </div>
</aside>

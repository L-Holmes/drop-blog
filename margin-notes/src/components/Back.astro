---
// A single, reliable "go back" control that links to the parent page
// (post -> category -> home). No JavaScript, so it always works.
interface Props { href: string; label: string; }
const { href, label } = Astro.props;
---
<a class="back" href={href} aria-label={`Back to ${label}`} title={`Back to ${label}`}>
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.4"
       stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M19 12H5" />
    <path d="M11 18l-6-6 6-6" />
  </svg>
  <span class="back__label">{label}</span>
</a>

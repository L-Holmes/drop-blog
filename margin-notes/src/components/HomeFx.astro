---
// A small, one-shot "science" flourish: green bubbles rising and popping,
// like something gently fizzing in a beaker. Plays once on arrival from
// outside the site (decided from document.referrer — no cookies/storage),
// for about 3 seconds, then removes its own canvas so there is zero
// ongoing cost. Time-based, so it works on mobile. Skipped under reduced
// motion. See STORAGE.md.
---
<canvas id="mnfx" aria-hidden="true"></canvas>
<style>
  #mnfx { position: fixed; inset: 0; width: 100%; height: 100%; pointer-events: none; z-index: 45; }
</style>
<script is:inline>
  (function () {
    var cv = document.getElementById('mnfx');
    if (!cv) return;
    function bail() { try { cv.remove(); } catch (e) {} }
    try {
      if (document.referrer && new URL(document.referrer).host === location.host) return bail();
    } catch (e) {}
    var mq = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)');
    if (mq && mq.matches) return bail();

    var ctx = cv.getContext('2d');
    var dpr = Math.min(window.devicePixelRatio || 1, 2);
    var W = window.innerWidth, H = window.innerHeight;
    cv.width = W * dpr; cv.height = H * dpr; ctx.setTransform(dpr, 0, 0, dpr, 0, 0);

    var GREENS = ['#5fa394', '#4e8f5e', '#6fae8f', '#3f8f5e'];
    var N = Math.min(40, Math.round(W / 24)), B = [];
    for (var i = 0; i < N; i++) {
      B.push({
        bx: Math.random() * W,
        y: H * 0.35 + Math.random() * H,      // staggered: some on-screen, some below
        r: 5 + Math.random() * 11,
        vy: 70 + Math.random() * 110,
        amp: 8 + Math.random() * 20,
        freq: 0.8 + Math.random() * 1.6,
        ph: Math.random() * 6.28,
        c: GREENS[i % GREENS.length]
      });
    }

    var start = null, DUR = 3200, dt = 1 / 60;
    function frame(t) {
      if (start === null) start = t;
      var el = t - start;
      var globalFade = el > DUR - 700 ? Math.max(0, (DUR - el) / 700) : 1;
      ctx.clearRect(0, 0, W, H);
      for (var i = 0; i < B.length; i++) {
        var b = B[i];
        b.y -= b.vy * dt;
        var x = b.bx + Math.sin((el / 1000) * b.freq + b.ph) * b.amp;
        // fade in low down, fade out near the top
        var a = Math.min(1, (H - b.y) / (H * 0.25)) * Math.min(1, (b.y) / (H * 0.25));
        a = Math.max(0, Math.min(1, a)) * globalFade;
        if (a <= 0) continue;
        ctx.globalAlpha = a * 0.5;
        ctx.fillStyle = b.c;
        ctx.beginPath(); ctx.arc(x, b.y, b.r, 0, 6.29); ctx.fill();
        ctx.globalAlpha = a;
        ctx.lineWidth = 1.6; ctx.strokeStyle = '#2a2018';
        ctx.beginPath(); ctx.arc(x, b.y, b.r, 0, 6.29); ctx.stroke();
        // highlight
        ctx.globalAlpha = a * 0.7;
        ctx.fillStyle = 'rgba(255,255,255,0.85)';
        ctx.beginPath(); ctx.arc(x - b.r * 0.32, b.y - b.r * 0.32, b.r * 0.22, 0, 6.29); ctx.fill();
      }
      if (el < DUR) requestAnimationFrame(frame);
      else bail();
    }
    requestAnimationFrame(frame);
  })();
</script>
